generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  password  String
  projects  Project[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("users")
}

model Project {
  id        String   @id @default(cuid())
  name      String
  domain    String
  apiKey    String   @unique @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions  Session[]
  events    Event[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([apiKey])
  @@map("projects")
}

model Session {
  id        String   @id @default(cuid())
  sessionId String   @unique
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  visitorId String?
  userAgent String?
  country   String?
  device    String?
  browser   String?
  startedAt DateTime @default(now())
  endedAt   DateTime?
  events    Event[]

  @@index([projectId])
  @@index([sessionId])
  @@map("sessions")
}

model Event {
  id        String    @id @default(cuid())
  type      EventType
  sessionId String
  session   Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  projectId String
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  page      String?
  element   String?
  metadata  Json?
  timestamp DateTime  @default(now())

  @@index([projectId, type, timestamp])
  @@index([sessionId, timestamp])
  @@index([projectId, page, timestamp])
  @@map("events")
}

enum EventType {
  PAGE_VIEW
  CLICK
  SCROLL
  AD_VIEW
  AD_CLICK
  PRODUCT_VIEW
  PRODUCT_INTERACTION
  TIME_ON_PAGE
  CUSTOM
}
